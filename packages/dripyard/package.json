{
  "name": "dripyard",
  "version": "0.9.15",
  "description": "Dashboard + worker supervisor for dripline projects. Reactive UI over .dripline/ workspaces, built on vex-core + dripline + flaregun.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dripyard": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && cd src/app/ui && bun run build",
    "build:ui": "cd src/app/ui && bun run build",
    "dev": "bun run src/main.ts",
    "dev:ui": "cd src/app/ui && bun run dev",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "bunx biome format --write src/",
    "lint": "bunx biome lint src/",
    "check": "bunx biome check src/"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "^1.2.17",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "vex-core": "^0.3.2",
    "dripline": "^0.9.15",
    "@miclivs/flaregun": "0.2.0",
    "commander": "^14.0.3",
    "chalk": "^5.6.2"
  }
}
